    "WebAPI": "WebAPI",
    "name": "name",
    "description": "description",
    "url": "url",
    "provider": "provider",
    "termsOfService": "termsOfService",
    "documentation": "documentation",
    "softwareVersion": "softwareVersion",
    "applicationCategory": "applicationCategory",
    "offers": "offers",
    "channel": {
      "@id": "landbot:channel",
      "@type": "@id"
    },
    "customer": {
      "@id": "landbot:customer",
      "@type": "@id"
    },
    "customerField": {
      "@id": "landbot:customerField",
      "@type": "@id"
    },
    "webhook": {
      "@id": "landbot:webhook",
      "@type": "@id"
    },
    "messageHook": {
      "@id": "landbot:messageHook",
      "@type": "@id"
    },
